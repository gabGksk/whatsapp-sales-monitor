{
  "name": "whatsapp-sales-monitor",
  "version": "0.1.0",
  "description": "Desktop scaffold for WhatsApp sales monitoring",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.5",
    "pino": "^9.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-vite": "^2.3.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.11.1",
    "typescript-eslint": "^8.8.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.gabgksk.whatsappsalesmonitor",
    "productName": "WhatsApp Sales Monitor",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
